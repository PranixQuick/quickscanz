{
  "expo": {
    "name": "QuickScanZ Premium",
    "slug": "pranixquick",
    "scheme": "quickscanz",
    "version": "0.1.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1120"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.quickscanz.premium",
      "infoPlist": {
        "NSCameraUsageDescription": "QuickScanZ uses your camera to scan bills and warranty cards.",
        "NSFaceIDUsageDescription": "QuickScanZ uses Face ID to unlock your account quickly and securely."
      }
    },
    "android": {
      "package": "com.quickscanz.warranty",
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B1120"
      },
      "permissions": [
        "CAMERA",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.CAMERA"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "quickscanz.app"
            },
            {
              "scheme": "https",
              "host": "www.quickscanz.app"
            },
            {
              "scheme": "https",
              "host": "quickscanz.com"
            },
            {
              "scheme": "https",
              "host": "www.quickscanz.com"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-local-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow QuickScanZ to access your camera to scan bills and warranty cards."
        }
      ],
      [
        "onesignal-expo-plugin",
        {
          "mode": "development"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25"
          }
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "2ea64344-9f20-404d-8052-53eeabf832bc"
      }
    },
    "owner": "pranixquicks-team"
  }
}
