EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# OneSignal App ID (found in the OneSignal dashboard under Settings ->
# Keys & IDs -> App ID). This must be the SAME OneSignal app used by
# supabase/functions/send-push-notifications/index.ts (ONESIGNAL_APP_ID /
# ONESIGNAL_API_KEY secrets) — otherwise the device will register with a
# different OneSignal app than the one the edge function sends through.
# See src/lib/push.ts and src/features/auth/AuthProvider.tsx for how this
# is used (OneSignal.initialize + OneSignal.login(user.id)).
EXPO_PUBLIC_ONESIGNAL_APP_ID=your-onesignal-app-id

# Base URL of the live Next.js API. Used by native/app/(tabs)/scan.tsx to call
# POST /api/ai/ocr (with an Authorization: Bearer <access_token> header — see
# feat/ocr-bearer-auth) and by native/app/(tabs)/claims.tsx to call
# POST /api/ai (M3 — see native/src/lib/api.ts for the auth caveat: that
# route does not yet have a confirmed Bearer-token fallback). Also used by
# native/app/pricing.tsx to open the web checkout in an in-app browser.
# Defaults to production in code if unset; override for local/dev API
# targets, e.g. http://192.168.1.23:3000 for a LAN dev server.
EXPO_PUBLIC_API_BASE_URL=https://www.quickscanz.com

# Base URL of pranix-aaria (voice understand/speak). No auth required — see
# native/src/features/aaria/aariaClient.ts. Defaults to the same public
# Render URL lib/aaria-client.ts (web) falls back to when AARIA_BASE_URL is
# unset server-side, so this is optional unless you're pointing at a local
# Aaria instance.
EXPO_PUBLIC_AARIA_BASE_URL=https://pranix-aaria.onrender.com
