EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Base URL of the live Next.js API. Used by native/app/(tabs)/scan.tsx to call
# POST /api/ai/ocr (with an Authorization: Bearer <access_token> header — see
# feat/ocr-bearer-auth). Defaults to production in code if unset; override for
# local/dev API targets, e.g. http://192.168.1.23:3000 for a LAN dev server.
EXPO_PUBLIC_API_BASE_URL=https://www.quickscanz.com
